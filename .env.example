# Documentation-only example values. Never use these placeholders as real secrets.
SECRET_KEY=replace_with_a_random_local_secret
# Use true only when the Backoffice is served over HTTPS.
SESSION_COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# HBntory PostgreSQL and initial administrator
# ---------------------------------------------------------------------------
POSTGRES_DB=hbntory
POSTGRES_USER=hbntory
POSTGRES_PASSWORD=replace_with_a_random_local_database_password
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+psycopg://hbntory:replace_with_a_random_local_database_password@localhost:5432/hbntory
INITIAL_ADMIN_PASSWORD=replace_with_a_random_initial_admin_password

# When a future Backoffice container shares the Compose network:
# DATABASE_URL=postgresql+psycopg://hbntory:replace_with_a_random_local_database_password@postgres:5432/hbntory

# ---------------------------------------------------------------------------
# Official External Product API (hbtn-edu/hbntory-products-api)
# ---------------------------------------------------------------------------
# Base URL used by HBntory consumers (Backoffice, Product MCP Server, etc.).
# Host access when the API is published on the machine:
PRODUCT_API_URL=http://localhost:5001

# When HBntory containers access the API through the host:
# PRODUCT_API_URL=http://host.docker.internal:5001

# When all services share the same Docker network (service name from compose):
# PRODUCT_API_URL=http://external-products-api:5000

# Host port published by docker-compose.yml (maps to the container port below).
PRODUCT_API_HOST_PORT=5001

# Official container environment (see hbtn-edu/hbntory-products-api .env.example).
# Container listen port — official default is 5000.
HBN_PRODUCTS_PORT=5000
# Optional simulated base latency in milliseconds (0 = no extra delay).
HBN_PRODUCTS_LATENCY_MS=0

# ---------------------------------------------------------------------------
# Product MCP Server (read-only product tools)
# ---------------------------------------------------------------------------
# Explicit HTTP timeout in seconds for ProductApiClient calls.
PRODUCT_API_TIMEOUT=5.0
# Optional explicit override for the Product MCP Server inside Compose.
# When unset, Compose derives the URL from HBN_PRODUCTS_PORT:
# http://external-products-api:${HBN_PRODUCTS_PORT:-5000}
# PRODUCT_API_URL_DOCKER=http://external-products-api:5000
# MCP process bind address/port (container listens on 0.0.0.0:8001 by default).
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_HOST_PORT=8001
MCP_TRANSPORT=streamable-http
MCP_LOG_LEVEL=INFO

BACKOFFICE_INTERNAL_URL=http://backoffice:5000/internal
INTERNAL_API_TOKEN=replace_with_a_random_internal_token
# Future AI service points at the Product MCP Streamable HTTP endpoint.
MCP_SERVER_URL=http://product-mcp-server:8001/mcp
# Host-side equivalent when the MCP server is published on the machine:
# MCP_SERVER_URL=http://localhost:8001/mcp
AI_PROVIDER=example_provider
MODEL_NAME=example_model

# Optional when the selected provider is Ollama.
OLLAMA_API_BASE=http://ollama:11434
