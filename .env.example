# Documentation-only example values. Never use these placeholders as real secrets.
SECRET_KEY=replace_with_a_random_local_secret
DATABASE_URL=postgresql://example_user:example_password@postgres:5432/hbntory_example

# ---------------------------------------------------------------------------
# Official External Product API (hbtn-edu/hbntory-products-api)
# ---------------------------------------------------------------------------
# Base URL used by HBntory consumers (Backoffice, Product MCP Server, etc.).
# Host access when the API is published on the machine:
PRODUCT_API_URL=http://localhost:5001

# When HBntory containers access the API through the host:
# PRODUCT_API_URL=http://host.docker.internal:5001

# When all services share the same Docker network (service name from compose):
# PRODUCT_API_URL=http://external-products-api:5000

# Host port published by docker-compose.yml (maps to the container port below).
PRODUCT_API_HOST_PORT=5001

# Official container environment (see hbtn-edu/hbntory-products-api .env.example).
# Container listen port — official default is 5000.
HBN_PRODUCTS_PORT=5000
# Optional simulated base latency in milliseconds (0 = no extra delay).
HBN_PRODUCTS_LATENCY_MS=0

BACKOFFICE_INTERNAL_URL=http://backoffice:5000/internal
INTERNAL_API_TOKEN=replace_with_a_random_internal_token
MCP_SERVER_URL=http://product-mcp-server:8001/mcp
AI_PROVIDER=example_provider
MODEL_NAME=example_model

# Optional when the selected provider is Ollama.
OLLAMA_API_BASE=http://ollama:11434
